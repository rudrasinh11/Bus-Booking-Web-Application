@model IEnumerable<BusBookingWebApp.Models.Schedule>

@{
    ViewData["Title"] = "Schedules";
    string searchQuery = Context?.Request?.Query["search"].ToString() ?? "";
}

<div class="container">
    <div class="trip-toolbar reveal">
        <div>
            <div class="page-kicker">Schedule board</div>
            <h1 class="section-title mb-2">Search schedules</h1>
            <p class="section-copy mb-0">Find routes by city or bus name and continue into the same booking flow.</p>
        </div>
        <span class="status-badge success"><i class="bi bi-activity"></i>Live inventory</span>
    </div>

    <form method="get" class="trip-search mb-4 reveal">
        <div class="row g-3 align-items-end">
            <div class="col-lg-10">
                <label class="form-label" for="search">Route or bus</label>
                <div class="input-shell">
                    <i class="bi bi-search"></i>
                    <input id="search" name="search" placeholder="Search by bus, origin, or destination" value="@searchQuery" class="form-control" />
                </div>
            </div>
            <div class="col-lg-2">
                <button type="submit" class="btn btn-primary w-100">Search</button>
            </div>
        </div>
    </form>

    @if (Model == null || !Model.Any())
    {
        <div class="empty-state reveal">
            <span class="icon-box mb-3"><i class="bi bi-calendar-x"></i></span>
            <h4 class="fw-bold">No schedules found</h4>
            <p class="text-secondary mb-0">Try a bus name, city, or broader route keyword.</p>
        </div>
    }
    else
    {
        <div class="trip-list">
            @foreach (var s in Model)
            {
                var route = s.Bus?.Route;
                var seatsBooked = s.Bookings?.Sum(b => b.SeatsBooked) ?? 0;
                var availableSeats = Math.Max((s.Bus?.TotalSeats ?? 0) - seatsBooked, 0);
                var duration = s.ArrivalTime - s.DepartureTime;
                var durationText = duration.TotalMinutes > 0 ? $"{(int)duration.TotalHours}h {duration.Minutes}m" : "Flexible";

                <article class="trip-card reveal">
                    <div class="trip-card-main">
                        <div>
                            <h2 class="bus-name">@(s.Bus?.Name ?? "Premium Coach")</h2>
                            <span class="bus-type"><i class="bi bi-bus-front"></i>@(s.Bus?.BusType ?? "Coach")</span>
                        </div>
                        <div>
                            <div class="route-line">
                                <div class="route-dot">
                                    <i class="bi bi-circle-fill text-primary small"></i>
                                    <div>
                                        <strong>@(route?.From ?? "Origin")</strong>
                                        <div class="text-secondary small">@s.DepartureTime.ToString("dd MMM, hh:mm tt")</div>
                                    </div>
                                </div>
                                <div class="route-connector"></div>
                                <div class="route-dot">
                                    <i class="bi bi-geo-alt-fill text-success"></i>
                                    <div>
                                        <strong>@(route?.To ?? "Destination")</strong>
                                        <div class="text-secondary small">@s.ArrivalTime.ToString("dd MMM, hh:mm tt")</div>
                                    </div>
                                </div>
                            </div>
                            <div class="trip-meta">
                                <span class="meta-pill"><i class="bi bi-clock"></i>@durationText</span>
                                <span class="meta-pill"><i class="bi bi-person-check"></i>@availableSeats seats</span>
                            </div>
                        </div>
                        <div>
                            <div class="fare">Rs. @s.Fare<small>/seat</small></div>
                        </div>
                        <a class="btn btn-primary px-4"
                           asp-controller="Booking"
                           asp-action="Book"
                           asp-route-scheduleId="@s.Id">
                            Book Now
                        </a>
                    </div>
                </article>
            }
        </div>
    }
</div>
