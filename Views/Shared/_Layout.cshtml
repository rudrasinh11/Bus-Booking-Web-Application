@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    var userId = HttpContextAccessor.HttpContext?.Session.GetInt32("UserId");
    var userName = HttpContextAccessor.HttpContext?.Session.GetString("UserName");
    var isAdmin = HttpContextAccessor.HttpContext?.Session.GetString("IsAdmin") == "1";
    var userInitial = string.IsNullOrWhiteSpace(userName) ? "U" : userName.Trim().Substring(0, 1).ToUpperInvariant();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@(ViewData["Title"] ?? "Bus Booking") - BusBooking</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg sticky-top">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2" href="/">
                <span class="brand-mark"><i class="bi bi-bus-front-fill"></i></span>
                <span>BusBooking</span>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                    @if (userId == null)
                    {
                        <li class="nav-item"><a class="nav-link" href="/Account/Register">Register</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Account/Login">Login</a></li>
                    }
                    else if (isAdmin)
                    {
                        <li class="nav-item"><a class="nav-link" href="/Admin/Dashboard">Dashboard</a></li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link" href="/Bus/List">Trips</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Booking/MyBookings">My Bookings</a></li>
                    }
                </ul>

                <div class="d-flex align-items-center gap-3">
                    @if (userId != null)
                    {
                        <span class="user-chip">
                            <span class="avatar">@userInitial</span>
                            <span>@userName</span>
                        </span>
                        <a class="btn btn-outline-primary btn-sm px-3" href="/Account/Logout">
                            <i class="bi bi-box-arrow-right me-1"></i>Logout
                        </a>
                    }
                    else
                    {
                        <a class="btn btn-primary btn-sm px-3" href="/Account/Login">
                            <i class="bi bi-person-circle me-1"></i>Sign in
                        </a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <main class="app-shell">
        @RenderBody()
    </main>

    <footer class="app-footer">
        <div class="container">
            <div class="footer-grid">
                <div>
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <span class="brand-mark"><i class="bi bi-bus-front-fill"></i></span>
                        <strong class="text-white fs-5">BusBooking</strong>
                    </div>
                    <p class="mb-0">Premium intercity bus booking with fast search, secure reservations, and comfortable journeys.</p>
                    <div class="social-links">
                        <a href="#" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
                        <a href="#" aria-label="Twitter"><i class="bi bi-twitter-x"></i></a>
                        <a href="#" aria-label="LinkedIn"><i class="bi bi-linkedin"></i></a>
                    </div>
                </div>
                <div>
                    <strong class="text-white">Company</strong>
                    <a href="/">Home</a>
                    <a href="/Bus/List">Trips</a>
                    <a href="/Booking/MyBookings">Bookings</a>
                </div>
                <div>
                    <strong class="text-white">Support</strong>
                    <a href="mailto:support@busbooking.com">Contact</a>
                    <a href="/Home/Privacy">Privacy</a>
                    <a href="#">Help Center</a>
                </div>
                <div>
                    <strong class="text-white">Legal</strong>
                    <a href="/Home/Privacy">Privacy</a>
                    <a href="#">Terms</a>
                    <a href="#">Refunds</a>
                </div>
                <div>
                    <strong class="text-white">Newsletter</strong>
                    <p class="mt-2 mb-3">Get route alerts and travel offers.</p>
                    <form class="newsletter" action="/" method="get">
                        <input class="form-control" type="email" placeholder="Email address" aria-label="Email address" />
                        <button class="btn btn-primary" type="submit" aria-label="Subscribe"><i class="bi bi-send-fill"></i></button>
                    </form>
                </div>
            </div>
            <div class="pt-4 mt-4 border-top border-secondary-subtle small">
                &copy; @DateTime.Now.Year BusBooking. Designed by Rudra.
            </div>
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
