@model IEnumerable<BusBookingWebApp.Models.Booking>

@{
    ViewData["Title"] = "My Bookings";
    var bookings = Model?.ToList() ?? new List<BusBookingWebApp.Models.Booking>();
    var upcoming = bookings.Count(b => b.TravelDate.Date >= DateTime.Today);
    var completed = bookings.Count(b => b.TravelDate.Date < DateTime.Today);
    var totalSpend = bookings.Sum(b => (b.Schedule?.Fare ?? 0) * b.SeatsBooked);
}

<div class="container">
    <div class="trip-toolbar reveal">
        <div>
            <div class="page-kicker">User dashboard</div>
            <h1 class="section-title mb-2">My bookings</h1>
            <p class="section-copy mb-0">A clean dashboard for current trips, past journeys, wallet value, and recent bookings.</p>
        </div>
        <a href="/Bus/List" class="btn btn-primary"><i class="bi bi-plus-circle me-2"></i>Book another trip</a>
    </div>

    <div class="dashboard-grid mb-4">
        <div class="dashboard-card reveal">
            <span class="icon-box"><i class="bi bi-calendar-check"></i></span>
            <h3 class="fw-bold mt-3 mb-0">@upcoming</h3>
            <p class="text-secondary mb-0">Upcoming Trips</p>
        </div>
        <div class="dashboard-card reveal">
            <span class="icon-box"><i class="bi bi-check2-circle"></i></span>
            <h3 class="fw-bold mt-3 mb-0">@completed</h3>
            <p class="text-secondary mb-0">Completed Trips</p>
        </div>
        <div class="dashboard-card reveal">
            <span class="icon-box"><i class="bi bi-x-circle"></i></span>
            <h3 class="fw-bold mt-3 mb-0">0</h3>
            <p class="text-secondary mb-0">Cancelled Trips</p>
        </div>
        <div class="dashboard-card reveal">
            <span class="icon-box"><i class="bi bi-wallet2"></i></span>
            <h3 class="fw-bold mt-3 mb-0">Rs. @totalSpend</h3>
            <p class="text-secondary mb-0">Wallet Value</p>
        </div>
        <div class="dashboard-card reveal">
            <span class="icon-box"><i class="bi bi-gift"></i></span>
            <h3 class="fw-bold mt-3 mb-0">@(bookings.Count * 120)</h3>
            <p class="text-secondary mb-0">Reward Points</p>
        </div>
    </div>

    @if (!bookings.Any())
    {
        <div class="empty-state reveal">
            <span class="icon-box mb-3"><i class="bi bi-ticket-perforated"></i></span>
            <h4 class="fw-bold">No bookings found</h4>
            <p class="text-secondary">Your next journey will appear here once you reserve a seat.</p>
            <a href="/Bus/List" class="btn btn-primary">Explore trips</a>
        </div>
    }
    else
    {
        <div class="trip-list">
            @foreach (var booking in bookings)
            {
                var fare = booking.Schedule?.Fare ?? 0;
                var total = fare * booking.SeatsBooked;
                var isUpcoming = booking.TravelDate.Date >= DateTime.Today;

                <article class="booking-card reveal">
                    <div class="booking-card-head">
                        <div>
                            <h2 class="bus-name">@(booking.Schedule?.Bus?.Route?.From ?? "Origin") to @(booking.Schedule?.Bus?.Route?.To ?? "Destination")</h2>
                            <div class="trip-meta">
                                <span class="meta-pill"><i class="bi bi-bus-front"></i>@(booking.Schedule?.Bus?.Name ?? "Bus")</span>
                                <span class="meta-pill"><i class="bi bi-calendar-event"></i>@booking.TravelDate.ToString("dd MMM yyyy")</span>
                                <span class="meta-pill"><i class="bi bi-person"></i>@booking.CustomerName</span>
                            </div>
                        </div>
                        <span class="status-badge @(isUpcoming ? "success" : "warning")">
                            <i class="bi @(isUpcoming ? "bi-clock-fill" : "bi-check-circle-fill")"></i>@(isUpcoming ? "Upcoming" : "Completed")
                        </span>
                    </div>

                    <div class="row g-3 my-3">
                        <div class="col-md-3">
                            <span class="text-secondary small d-block">Seat</span>
                            <strong>@booking.SeatsBooked (@booking.SelectedSeatNumbers)</strong>
                        </div>
                        <div class="col-md-3">
                            <span class="text-secondary small d-block">Price</span>
                            <strong>Rs. @total</strong>
                        </div>
                        <div class="col-md-3">
                            <span class="text-secondary small d-block">Booked</span>
                            <strong>@booking.BookingTime.ToString("dd MMM, hh:mm tt")</strong>
                        </div>
                        <div class="col-md-3">
                            <span class="text-secondary small d-block">Status</span>
                            <strong>Confirmed</strong>
                        </div>
                    </div>

                    <div class="booking-card-actions">
                        <a asp-action="DownloadTicket" asp-route-bookingId="@booking.Id" class="btn btn-outline-primary">
                            <i class="bi bi-download me-2"></i>Download Ticket
                        </a>
                        <form asp-action="CancelBooking" asp-route-id="@booking.Id" method="post" class="m-0">
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-x-circle me-2"></i>Cancel
                            </button>
                        </form>
                    </div>
                </article>
            }
        </div>
    }
</div>
