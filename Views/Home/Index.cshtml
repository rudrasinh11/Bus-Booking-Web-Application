@{
    ViewData["Title"] = "Travel Smarter";
}

<section class="hero-section">
    <div class="container">
        <div class="hero-grid">
            <div class="reveal">
                <div class="page-kicker">Premium bus travel</div>
                <h1 class="hero-title">Travel Smarter. <span>Book Faster.</span></h1>
                <p class="hero-copy">
                    Compare trusted routes, choose comfortable coaches, reserve your seats, and keep every journey organized from one polished booking experience.
                </p>
                <div class="hero-actions">
                    <a href="/Bus/List" class="btn btn-primary btn-lg px-4">
                        <i class="bi bi-search me-2"></i>Find buses
                    </a>
                    <a href="/Booking/MyBookings" class="btn btn-outline-primary btn-lg px-4">
                        <i class="bi bi-ticket-perforated me-2"></i>My bookings
                    </a>
                </div>
                <div class="hero-stats">
                    <div class="stat-pill">
                        <strong>120+</strong>
                        <span>Daily routes</span>
                    </div>
                    <div class="stat-pill">
                        <strong>4.8</strong>
                        <span>Rider rating</span>
                    </div>
                    <div class="stat-pill">
                        <strong>24/7</strong>
                        <span>Support desk</span>
                    </div>
                </div>
            </div>

            <div class="hero-visual reveal">
                <div class="floating-card top"><i class="bi bi-shield-check text-success"></i>Safe payments</div>
                <div class="bus-illustration">
                    <svg viewBox="0 0 620 430" role="img" aria-label="Modern bus illustration" class="w-100">
                        <defs>
                            <linearGradient id="busBody" x1="0" x2="1" y1="0" y2="1">
                                <stop offset="0%" stop-color="#2563eb" />
                                <stop offset="55%" stop-color="#4f46e5" />
                                <stop offset="100%" stop-color="#06b6d4" />
                            </linearGradient>
                            <linearGradient id="window" x1="0" x2="1">
                                <stop offset="0%" stop-color="#e0f2fe" />
                                <stop offset="100%" stop-color="#ffffff" />
                            </linearGradient>
                        </defs>
                        <path d="M85 318 C130 386 474 389 536 318" fill="none" stroke="#dbeafe" stroke-width="24" stroke-linecap="round" />
                        <rect x="76" y="118" width="468" height="190" rx="42" fill="url(#busBody)" />
                        <rect x="116" y="152" width="284" height="70" rx="20" fill="url(#window)" opacity="0.92" />
                        <rect x="419" y="152" width="76" height="70" rx="20" fill="#dbeafe" opacity="0.96" />
                        <rect x="116" y="244" width="350" height="22" rx="11" fill="#bfdbfe" opacity="0.6" />
                        <circle cx="174" cy="310" r="42" fill="#0f172a" />
                        <circle cx="174" cy="310" r="20" fill="#94a3b8" />
                        <circle cx="446" cy="310" r="42" fill="#0f172a" />
                        <circle cx="446" cy="310" r="20" fill="#94a3b8" />
                        <path d="M520 210 h28 c15 0 28 12 28 28 v22 h-56z" fill="#10b981" />
                        <circle cx="98" cy="250" r="12" fill="#f59e0b" />
                        <circle cx="525" cy="250" r="12" fill="#fef3c7" />
                    </svg>
                </div>
                <div class="floating-card bottom"><i class="bi bi-geo-alt-fill text-primary"></i>Live tracking</div>
            </div>
        </div>
    </div>
    <div class="wave-divider"></div>
</section>

<section class="container">
    <form action="/Bus/List" method="get" class="search-panel reveal">
        <div class="search-grid">
            <div>
                <label class="form-label" for="from">From</label>
                <div class="input-shell">
                    <i class="bi bi-geo-alt"></i>
                    <input id="from" name="from" class="form-control" placeholder="Mumbai" />
                </div>
            </div>
            <div>
                <label class="form-label" for="to">To</label>
                <div class="input-shell">
                    <i class="bi bi-pin-map"></i>
                    <input id="to" name="to" class="form-control" placeholder="Pune" />
                </div>
            </div>
            <div>
                <label class="form-label" for="travelDate">Travel Date</label>
                <div class="input-shell">
                    <i class="bi bi-calendar-event"></i>
                    <input id="travelDate" type="date" class="form-control" min="@DateTime.Now.ToString("yyyy-MM-dd")" />
                </div>
            </div>
            <div>
                <label class="form-label" for="passengers">Passengers</label>
                <div class="input-shell">
                    <i class="bi bi-people"></i>
                    <select id="passengers" class="form-select">
                        <option>1 Passenger</option>
                        <option>2 Passengers</option>
                        <option>3 Passengers</option>
                        <option>4 Passengers</option>
                    </select>
                </div>
            </div>
            <button type="submit" class="btn btn-primary px-4">
                <i class="bi bi-arrow-right me-2"></i>Search
            </button>
        </div>
    </form>
</section>

<section class="container py-5">
    <div class="d-flex flex-column flex-lg-row align-items-lg-end justify-content-between gap-3 mb-4 reveal">
        <div>
            <div class="page-kicker">Why travelers choose us</div>
            <h2 class="section-title mb-2">A smoother way to move between cities</h2>
        </div>
        <p class="section-copy mb-0">Designed for quick decisions, secure checkout, and a calm travel day.</p>
    </div>

    <div class="feature-grid">
        <div class="feature-card reveal">
            <span class="icon-box"><i class="bi bi-broadcast-pin"></i></span>
            <h5 class="mt-3 mb-2 fw-bold">Live Tracking</h5>
            <p class="text-secondary mb-0">Stay informed from pickup to arrival.</p>
        </div>
        <div class="feature-card reveal">
            <span class="icon-box"><i class="bi bi-lightning-charge"></i></span>
            <h5 class="mt-3 mb-2 fw-bold">Instant Booking</h5>
            <p class="text-secondary mb-0">Reserve seats in a few focused clicks.</p>
        </div>
        <div class="feature-card reveal">
            <span class="icon-box"><i class="bi bi-credit-card-2-front"></i></span>
            <h5 class="mt-3 mb-2 fw-bold">Safe Payments</h5>
            <p class="text-secondary mb-0">A premium checkout feel with clear totals.</p>
        </div>
        <div class="feature-card reveal">
            <span class="icon-box"><i class="bi bi-stars"></i></span>
            <h5 class="mt-3 mb-2 fw-bold">Luxury Coaches</h5>
            <p class="text-secondary mb-0">Modern buses with better comfort signals.</p>
        </div>
        <div class="feature-card reveal">
            <span class="icon-box"><i class="bi bi-headset"></i></span>
            <h5 class="mt-3 mb-2 fw-bold">24/7 Support</h5>
            <p class="text-secondary mb-0">Help is always close when plans change.</p>
        </div>
    </div>
</section>
