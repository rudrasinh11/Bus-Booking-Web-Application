@model BusBookingWebApp.Models.User
@{
    ViewData["Title"] = "Register";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-xl-5">
            <div class="auth-card reveal">
                <div class="text-center mb-4">
                    <span class="icon-box mb-3"><i class="bi bi-person-plus"></i></span>
                    <div class="page-kicker">Start travelling</div>
                    <h1 class="section-title">Create account</h1>
                    <p class="text-secondary mb-0">Save bookings, download tickets, and manage your trips faster.</p>
                </div>

                <form method="post" asp-action="Register">
                    <div class="mb-3">
                        <label class="form-label" asp-for="UserName">Username</label>
                        <div class="input-shell">
                            <i class="bi bi-person"></i>
                            <input asp-for="UserName" class="form-control" required />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" asp-for="Email">Email</label>
                        <div class="input-shell">
                            <i class="bi bi-envelope"></i>
                            <input asp-for="Email" class="form-control" type="email" required />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" asp-for="Password">Password</label>
                        <div class="input-shell">
                            <i class="bi bi-lock"></i>
                            <input asp-for="Password" class="form-control" type="password" required />
                        </div>
                    </div>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger rounded-4">@ViewBag.Error</div>
                    }
                    @if (ViewBag.Success != null)
                    {
                        <div class="alert alert-success rounded-4">@ViewBag.Success</div>
                    }

                    <button type="submit" class="btn btn-primary w-100">Register</button>
                </form>

                <p class="text-center mt-4 mb-0">
                    Already have an account? <a href="/Account/Login" class="fw-bold">Login</a>
                </p>
            </div>
        </div>
    </div>
</div>
